{
  "ConnectionStrings": {
    "StaDb": "Host={{DB_HOST}};Port=5432;Database={{DB_NAME}};Username={{DB_USER}};Password={{DB_PASSWORD}};Pooling=true;Maximum Pool Size=10;Command Timeout=120"
  },
  "Jwt": {
    "Secret": "{{JWT_SECRET}}",
    "Issuer": "STA.Api",
    "Audience": "STA.Client",
    "ExpirationHours": 8
  },
  "Ldap": {
    "Enabled": "{{LDAP_ENABLED}}",
    "Server": "{{LDAP_SERVER}}",
    "BaseDn": "{{LDAP_BASEDN}}",
    "Domain": "{{LDAP_DOMAIN}}"
  },
  "StaSettings": {
    "NomeSistema": "STA",
    "CnProcesso": 1,
    "Arquivo7Zip": "C:\\Program Files\\7-Zip\\7z.exe",
    "TimeoutCompactacaoMs": 1800000,
    "SobreEscreverArquivos": true,
    "QtdDiasExcluirLog": 5,
    "GeraLogSucessoBancoDados": true,
    "UseXmlFallback": false
  },
  "AllowedOrigins": ["{{FRONTEND_URL}}"],
  "Logging": {
    "LogLevel": {
      "Default": "{{LOG_LEVEL}}",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
